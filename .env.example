# ─────────────────────────────────────────────
# LinkedIn
# ─────────────────────────────────────────────
# Get this from your browser cookies after logging in to LinkedIn.
# In Chrome DevTools → Application → Cookies → https://www.linkedin.com → li_at
LINKEDIN_LI_AT=paste_your_li_at_cookie_here

# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → follow prompts
# 2. Copy the API token here
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWxyz

# 3. Send any message to your bot, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    and copy the "id" value from "chat" → "id"
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────────
# Tuning (optional)
# ─────────────────────────────────────────────
# Max jobs to send per source per run (prevents first-run flood). Default: 50
MAX_NEW_JOBS_PER_SOURCE=50

